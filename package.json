{
  "name": "wildscape-europe",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Premium camping discovery platform with 3D terrain visualization",
  "author": "Alex Cinovoj <alex@techtideai.com> (TechTideAI)",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/Alexi5000/WildScape-Europe.git"
  },
  "bugs": {
    "url": "https://github.com/Alexi5000/WildScape-Europe/issues"
  },
  "homepage": "https://github.com/Alexi5000/WildScape-Europe#readme",
  "keywords": [
    "camping",
    "europe",
    "3d-maps",
    "react",
    "typescript",
    "three.js",
    "mapbox",
    "outdoor",
    "travel",
    "wilderness"
  ],
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "lint:fix": "eslint . --ext ts,tsx --fix",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "validate": "npm run docs:check && npm run type-check && npm run lint && npm run test:ci && npm run build",
    "format": "prettier --write \"src/**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "analyze": "npx vite-bundle-analyzer",
    "docs:check": "node scripts/check-docs.mjs",
    "hygiene": "npm run validate",
    "test:ci": "vitest run --coverage"
  },
  "dependencies": {
    "@react-three/drei": "^9.88.0",
    "@react-three/fiber": "^8.15.0",
    "clsx": "^2.0.0",
    "framer-motion": "^10.16.0",
    "gsap": "^3.12.0",
    "lenis": "^1.3.4",
    "lucide-react": "^0.263.0",
    "mapbox-gl": "^2.15.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.8.0",
    "three": "^0.157.0",
    "zustand": "^4.4.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/mapbox-gl": "^2.7.0",
    "@types/node": "^25.9.1",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@types/three": "^0.157.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "@vitejs/plugin-react": "^4.1.0",
    "@vitest/coverage-v8": "^4.1.6",
    "autoprefixer": "^10.4.14",
    "eslint": "^8.45.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.3",
    "jsdom": "^29.1.1",
    "postcss": "^8.4.24",
    "prettier": "^3.0.0",
    "tailwindcss": "^3.3.0",
    "terser": "^5.19.0",
    "typescript": "^5.2.0",
    "vite": "^4.5.0",
    "vitest": "^4.1.6"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "release": {
    "current": "1.0.0",
    "channel": "stable",
    "codename": "Release 1.0"
  }
}
