# WildScape Europe - Environment Variables
# Copy this file to .env and fill in your values

# ===========================================
# Mapbox Configuration
# ===========================================
# Get your token at: https://account.mapbox.com/access-tokens/
VITE_MAPBOX_TOKEN=your_mapbox_token_here

# ===========================================
# Analytics
# ===========================================
# Google Analytics Tracking ID (optional)
VITE_GA_TRACKING_ID=

# ===========================================
# API Configuration
# ===========================================
# Base URL for API calls (if using custom backend)
VITE_API_BASE_URL=

# ===========================================
# Feature Flags
# ===========================================
# Enable/disable features
VITE_ENABLE_ANALYTICS=false
VITE_ENABLE_SOUND=true
VITE_ENABLE_WEATHER_EFFECTS=true
VITE_ENABLE_3D_TERRAIN=true

# ===========================================
# Development
# ===========================================
# Set to 'development' or 'production'
NODE_ENV=development

# Enable debug mode
VITE_DEBUG=false

# ===========================================
# Third-Party Services (optional)
# ===========================================
# Sentry DSN for error tracking
VITE_SENTRY_DSN=

# Hotjar Site ID for user analytics
VITE_HOTJAR_ID=

# ===========================================
# Build Configuration
# ===========================================
# Base path for deployment (e.g., /wildscape-europe/)
VITE_BASE_PATH=/

# CDN URL for assets (optional)
VITE_CDN_URL=

